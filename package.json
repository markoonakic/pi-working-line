{
  "name": "@markoonakic/pi-working-line",
  "version": "0.1.3",
  "description": "Claude-style working message phrases and elapsed timer for Pi.",
  "type": "module",
  "license": "MIT",
  "author": "Marko Nakic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markoonakic/pi-working-line.git"
  },
  "bugs": {
    "url": "https://github.com/markoonakic/pi-working-line/issues"
  },
  "homepage": "https://github.com/markoonakic/pi-working-line#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "working-message",
    "spinner"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/markoonakic/pi-working-line/main/assets/working-line-menu.png"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@mariozechner/pi-tui": "^0.66.1",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
